PORT=1234
DEV_PORT=1235
NEXTCLOUD_URL=https://your-cloud-url
NEXT_PUBLIC_ENABLE_LOGIN=false
NEXT_PUBLIC_DEV_USER=peter
NEXT_PUBLIC_CHESS_URL=http://localhost:1999
NEXT_PUBLIC_WORD_URL=http://localhost:2000

# MariaDB: estos valores son para correr `games` sin dockerizar (npm run
# dev/start) contra el MariaDB del `docker compose up`, igual que
# NEXT_PUBLIC_CHESS_URL/WORD_URL apuntan a localhost. Dentro de
# docker-compose.yml, el propio servicio "games" ya sobreescribe
# MARIADB_HOST/PORT a "mariadb"/3306 (red interna de compose), así que solo
# DATABASE/USER/PASSWORD/ROOT_PASSWORD de aquí abajo se usan en ese caso.
MARIADB_HOST=localhost
MARIADB_PORT=1010
MARIADB_DATABASE=games
MARIADB_USER=games
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-root
