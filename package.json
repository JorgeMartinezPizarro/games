{
  "name": "web-bookmarks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node run.js dev",
    "build": "next build",
    "start": "node run.js start",
    "lint": "next lint",
    "test": "node run-unit-tests.js",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:down && node -e \"require('fs').mkdirSync('cache',{recursive:true})\" && playwright test",
    "test:e2e:down": "docker compose -f docker-compose.yml -f docker-compose.e2e.yml --env-file .env.e2e -p games-e2e down -v"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@types/nodemailer": "^6.4.16",
    "@types/utf8": "^3.0.3",
    "cheerio": "^1.0.0",
    "chess.js": "^1.0.0-beta.8",
    "cookie": "^1.0.1",
    "dotenv": "^16.4.5",
    "mysql2": "^3.22.6",
    "next": "^16.2.9",
    "node-id3": "^0.2.6",
    "react": "^19.2.7",
    "react-chessboard": "^4.0.0",
    "react-datepicker": "^8.2.1",
    "react-dom": "^19.2.7",
    "react-player": "^2.16.0",
    "simple-oauth2": "^5.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/fluent-ffmpeg": "^2.1.25",
    "@types/node": "^20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/simple-oauth2": "^5.0.7",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
